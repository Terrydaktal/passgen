#!/bin/sh
set -eu

ITERATIONS=100000
DKLEN=64
MODE="pbkdf2"

usage() {
  cat <<'EOF'
Usage: passgen [--argon]

Default mode uses PBKDF2-HMAC-SHA256 (OpenSSL).
Use --argon to switch to Argon2id mode (argon2 CLI binary required).
EOF
}

prompt_tty() {
  printf '%s' "$1" > /dev/tty
  IFS= read -r ans < /dev/tty || return 1
  printf '%s' "$ans"
}

prompt_secret_tty() {
  printf '%s' "$1" > /dev/tty
  oldstty=$(stty -g < /dev/tty) || return 1
  stty -echo < /dev/tty || return 1
  IFS= read -r ans < /dev/tty || {
    stty "$oldstty" < /dev/tty
    return 1
  }
  stty "$oldstty" < /dev/tty
  printf '\n' > /dev/tty
  printf '%s' "$ans"
}

derive_key_bin() {
  salt=$1
  key_material=$2
  openssl kdf -binary -keylen "$DKLEN" \
    -kdfopt digest:SHA256 \
    -kdfopt "pass:$key_material" \
    -kdfopt "salt:$salt" \
    -kdfopt "iter:$ITERATIONS" \
    PBKDF2
}

derive_key_argon_bin() {
  salt=$1
  key_material=$2
  time_cost=$3
  mem_kib=$4
  parallelism=$5
  tmp=""

  if ! command -v argon2 >/dev/null 2>&1; then
    printf '%s\n' "Error: argon2 binary not found." >&2
    printf '%s\n' "Install it (Debian/Ubuntu): sudo apt install argon2" >&2
    return 1
  fi

  if [ "${#salt}" -lt 8 ]; then
    printf '%s\n' "Error: combined Site+Username must be at least 8 characters for argon2 salt." > /dev/tty
    return 1
  fi

  tmp=$(mktemp) || return 1
  if ! printf '%s' "$key_material" \
    | argon2 "$salt" -id -t "$time_cost" -k "$mem_kib" -p "$parallelism" -l "$DKLEN" -r > "$tmp"
  then
    rm -f "$tmp"
    printf '%s\n' "Error: argon2 failed with the provided parameters." > /dev/tty
    return 1
  fi

  cat "$tmp"
  rm -f "$tmp"
}

z85_encode_stream() {
  od -An -tx1 -v | tr -d ' \n' | awk '
    BEGIN {
      alpha="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ.-:+=^!/*?&<>()[]{}@%$#"
      pow4=85*85*85*85; pow3=85*85*85; pow2=85*85
    }
    function h2d(h, i, c, p, v) {
      v=0
      for (i=1; i<=length(h); i++) {
        c=substr(h, i, 1)
        p=index("0123456789abcdef", c)-1
        v=v*16+p
      }
      return v
    }
    {
      hex=tolower($0)
      if (length(hex) % 8 != 0) {
        exit 2
      }
      for (i=1; i<=length(hex); i+=8) {
        v=h2d(substr(hex, i, 8))
        d1=int(v/pow4); v-=d1*pow4
        d2=int(v/pow3); v-=d2*pow3
        d3=int(v/pow2); v-=d3*pow2
        d4=int(v/85); d5=v-d4*85
        printf "%s%s%s%s%s", \
          substr(alpha, d1+1, 1), \
          substr(alpha, d2+1, 1), \
          substr(alpha, d3+1, 1), \
          substr(alpha, d4+1, 1), \
          substr(alpha, d5+1, 1)
      }
    }'
}

prompt_int_tty() {
  name=$1
  prompt=$2
  minv=$3
  maxv=$4

  while :; do
    s=$(prompt_tty "$prompt") || return 1
    case "$s" in
      ''|*[!0-9]*)
        printf '%s\n' "Error: $name must be an integer between $minv and $maxv." > /dev/tty
        continue
        ;;
    esac
    if [ "$s" -lt "$minv" ] || [ "$s" -gt "$maxv" ]; then
      printf '%s\n' "Error: $name must be between $minv and $maxv." > /dev/tty
      continue
    fi
    printf '%s' "$s"
    return 0
  done
}

while [ $# -gt 0 ]; do
  case "$1" in
    --argon)
      MODE="argon"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf '%s\n' "Error: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

if [ "$MODE" = "pbkdf2" ] && [ -z "${PASSGEN_PEPPER:-}" ]; then
  printf '%s\n' "Error: PASSGEN_PEPPER environment variable is not set." >&2
  exit 1
fi

if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
  printf '%s\n' "Error: No /dev/tty available. Run from an interactive terminal." >&2
  exit 1
fi

site=$(prompt_tty "Site: ")
username=$(prompt_tty "Username: ")

if [ "$MODE" = "argon" ]; then
  master=$(prompt_secret_tty "Password: ")
  time_cost=$(prompt_int_tty "Time" "Time: " 1 50)
  mem_kib=$(prompt_int_tty "Memory" "Memory: " 8192 8388608)
  parallelism=$(prompt_int_tty "Parallelism" "Parallelism: " 1 256)
else
  master=$(prompt_secret_tty "Master Password: ")
fi

enc=""
while [ "$enc" != "64" ] && [ "$enc" != "85" ]; do
  enc=$(prompt_tty "Encoding (64 Base64, 85 Z85): ")
  if [ "$enc" != "64" ] && [ "$enc" != "85" ]; then
    printf '%s\n' "Error: encoding must be 64 or 85." > /dev/tty
  fi
done

length=""
if [ "$MODE" = "pbkdf2" ]; then
  if [ "$enc" = "85" ]; then
    hint="Length (blank=full; hint: 44 or 80): "
  else
    hint="Length (blank=full; hint: 20 or 86): "
  fi

  length_s=$(prompt_tty "$hint")
  if [ -n "$length_s" ]; then
    case "$length_s" in
      *[!0-9]*)
        printf '%s\n' "Error: length must be a positive integer (or blank)." > /dev/tty
        exit 2
        ;;
    esac
    if [ "$length_s" -le 0 ]; then
      printf '%s\n' "Error: length must be a positive integer (or blank)." > /dev/tty
      exit 2
    fi
    length="$length_s"
  fi
fi

salt="${site}${username}"
key_material="${master}${PASSGEN_PEPPER:-}"

if [ "$MODE" = "argon" ]; then
  raw_tmp=$(mktemp) || exit 1
  if ! derive_key_argon_bin "$salt" "$key_material" "$time_cost" "$mem_kib" "$parallelism" > "$raw_tmp"; then
    rm -f "$raw_tmp"
    exit 1
  fi
  if [ "$enc" = "64" ]; then
    out=$(base64 < "$raw_tmp" | tr -d '\n=')
  else
    out=$(z85_encode_stream < "$raw_tmp")
  fi
  rm -f "$raw_tmp"
else
  if [ "$enc" = "64" ]; then
    out=$(derive_key_bin "$salt" "$key_material" | base64 | tr -d '\n=')
  else
    out=$(derive_key_bin "$salt" "$key_material" | z85_encode_stream)
  fi
fi

if [ -n "$length" ]; then
  out=$(printf '%s' "$out" | cut -c1-"$length")
fi

# IMPORTANT: do NOT add a newline.
printf '%s' "$out"
