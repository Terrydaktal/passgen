#!/usr/bin/env bash
set -euo pipefail

python3 - <<'PY'
import base64
import getpass
import hashlib
import os
import sys

Z85_ALPHABET = "0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ.-:+=^!/*?&<>()[]{}@%$#"

pepper_env = os.environ.get("PASSGEN_PEPPER")
if not pepper_env:
    # Print directly to stderr to ensure visibility even if stdout is piped
    sys.stderr.write("Error: PASSGEN_PEPPER environment variable is not set.\n")
    sys.exit(1)

PEPPER = pepper_env.encode("utf-8")
ITERATIONS = 100_000
DKLEN = 64  # bytes

def z85_encode(data: bytes) -> str:
    if len(data) % 4 != 0:
        raise ValueError("Z85 encoding requires input length to be a multiple of 4.")
    out = []
    for i in range(0, len(data), 4):
        v = int.from_bytes(data[i:i+4], "big", signed=False)
        out.append(Z85_ALPHABET[(v // (85 ** 4)) % 85])
        out.append(Z85_ALPHABET[(v // (85 ** 3)) % 85])
        out.append(Z85_ALPHABET[(v // (85 ** 2)) % 85])
        out.append(Z85_ALPHABET[(v // 85) % 85])
        out.append(Z85_ALPHABET[v % 85])
    return "".join(out)

def prompt_tty(prompt: str) -> str:
    # Keep stdout clean for piping; interact via controlling terminal.
    if not (os.path.exists("/dev/tty") and os.access("/dev/tty", os.R_OK | os.W_OK)):
        raise RuntimeError("No /dev/tty available. Run from an interactive terminal.")
    with open("/dev/tty", "r", encoding="utf-8", errors="replace") as tin, \
         open("/dev/tty", "w", encoding="utf-8", errors="replace") as tout:
        tout.write(prompt)
        tout.flush()
        return tin.readline().rstrip("\n")

def main() -> int:
    site = prompt_tty("Site: ")
    username = prompt_tty("Username: ")
    master = getpass.getpass("Master Password: ")

    enc = ""
    while enc not in ("64", "85"):
        enc = prompt_tty("Encoding (64 Base64, 85 Z85): ").strip()
        if enc not in ("64", "85"):
            with open("/dev/tty", "w", encoding="utf-8", errors="replace") as tout:
                tout.write("Error: encoding must be 64 or 85.\n")
                tout.flush()

    hint = "Length (blank=full; hint: 44 or 80): " if enc == "85" else "Length (blank=full; hint: 20 or 86): "
    length_s = prompt_tty(hint).strip()
    length = None
    if length_s:
        if not length_s.isdigit() or int(length_s) <= 0:
            with open("/dev/tty", "w", encoding="utf-8", errors="replace") as tout:
                tout.write("Error: length must be a positive integer (or blank).\n")
                tout.flush()
            return 2
        length = int(length_s)

    salt = (site + username).encode("utf-8")
    key = master.encode("utf-8") + PEPPER
    dk = hashlib.pbkdf2_hmac("sha256", key, salt, ITERATIONS, dklen=DKLEN)

    if enc == "64":
        out = base64.b64encode(dk).decode("ascii").rstrip("=")
    else:
        out = z85_encode(dk)

    if length is not None:
        out = out[:length]

    # IMPORTANT: do NOT add a newline.
    # With cryptsetup --key-file -, reading does not stop at newline characters. 2
    try:
        sys.stdout.write(out)
        sys.stdout.flush()
    except BrokenPipeError:
        # Python ignores SIGPIPE by default and turns it into BrokenPipeError. 3
        # Exit quietly if downstream closed early.
        return 0

    return 0

raise SystemExit(main())
PY
