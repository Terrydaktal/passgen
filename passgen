#!/bin/sh
set -eu

ITERATIONS=100000
DKLEN=64
Z85_ALPHABET='0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ.-:+=^!/*?&<>()[]{}@%$#'

prompt_tty() {
  printf '%s' "$1" > /dev/tty
  IFS= read -r ans < /dev/tty || return 1
  printf '%s' "$ans"
}

prompt_secret_tty() {
  printf '%s' "$1" > /dev/tty
  oldstty=$(stty -g < /dev/tty) || return 1
  stty -echo < /dev/tty || return 1
  IFS= read -r ans < /dev/tty || {
    stty "$oldstty" < /dev/tty
    return 1
  }
  stty "$oldstty" < /dev/tty
  printf '\n' > /dev/tty
  printf '%s' "$ans"
}

derive_key_bin() {
  salt=$1
  key_material=$2
  openssl kdf -binary -keylen "$DKLEN" \
    -kdfopt digest:SHA256 \
    -kdfopt "pass:$key_material" \
    -kdfopt "salt:$salt" \
    -kdfopt "iter:$ITERATIONS" \
    PBKDF2
}

z85_encode_stream() {
  od -An -tx1 -v | tr -d ' \n' | awk '
    BEGIN {
      alpha="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ.-:+=^!/*?&<>()[]{}@%$#"
      pow4=85*85*85*85; pow3=85*85*85; pow2=85*85
    }
    function h2d(h, i, c, p, v) {
      v=0
      for (i=1; i<=length(h); i++) {
        c=substr(h, i, 1)
        p=index("0123456789abcdef", c)-1
        v=v*16+p
      }
      return v
    }
    {
      hex=tolower($0)
      if (length(hex) % 8 != 0) {
        exit 2
      }
      for (i=1; i<=length(hex); i+=8) {
        v=h2d(substr(hex, i, 8))
        d1=int(v/pow4); v-=d1*pow4
        d2=int(v/pow3); v-=d2*pow3
        d3=int(v/pow2); v-=d3*pow2
        d4=int(v/85); d5=v-d4*85
        printf "%s%s%s%s%s", \
          substr(alpha, d1+1, 1), \
          substr(alpha, d2+1, 1), \
          substr(alpha, d3+1, 1), \
          substr(alpha, d4+1, 1), \
          substr(alpha, d5+1, 1)
      }
    }'
}

if [ -z "${PASSGEN_PEPPER:-}" ]; then
  printf '%s\n' "Error: PASSGEN_PEPPER environment variable is not set." >&2
  exit 1
fi

if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
  printf '%s\n' "Error: No /dev/tty available. Run from an interactive terminal." >&2
  exit 1
fi

site=$(prompt_tty "Site: ")
username=$(prompt_tty "Username: ")
master=$(prompt_secret_tty "Master Password: ")

enc=""
while [ "$enc" != "64" ] && [ "$enc" != "85" ]; do
  enc=$(prompt_tty "Encoding (64 Base64, 85 Z85): ")
  if [ "$enc" != "64" ] && [ "$enc" != "85" ]; then
    printf '%s\n' "Error: encoding must be 64 or 85." > /dev/tty
  fi
done

if [ "$enc" = "85" ]; then
  hint="Length (blank=full; hint: 44 or 80): "
else
  hint="Length (blank=full; hint: 20 or 86): "
fi

length_s=$(prompt_tty "$hint")
length=""
if [ -n "$length_s" ]; then
  case "$length_s" in
    *[!0-9]*)
      printf '%s\n' "Error: length must be a positive integer (or blank)." > /dev/tty
      exit 2
      ;;
  esac
  if [ "$length_s" -le 0 ]; then
    printf '%s\n' "Error: length must be a positive integer (or blank)." > /dev/tty
    exit 2
  fi
  length="$length_s"
fi

salt="${site}${username}"
key_material="${master}${PASSGEN_PEPPER}"

if [ "$enc" = "64" ]; then
  out=$(derive_key_bin "$salt" "$key_material" | base64 | tr -d '\n=')
else
  out=$(derive_key_bin "$salt" "$key_material" | z85_encode_stream)
fi

if [ -n "$length" ]; then
  out=$(printf '%s' "$out" | cut -c1-"$length")
fi

# IMPORTANT: do NOT add a newline.
printf '%s' "$out"
